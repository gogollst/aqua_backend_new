<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="Aqua.UserService"
                   namespace="Aqua.UserService.Ldap">
  <class name="LdapGroupRoleMapping" table="ldap_group_role_mapping">
    <id name="Id" column="id"><generator class="native" /></id>
    <property name="CustomerId"  column="customer_id"   not-null="true" />
    <property name="LdapGroupDn" column="ldap_group_dn" not-null="true" length="512" />
    <property name="RoleId"      column="role_id"       not-null="true" />
    <property name="CreatedAt"   column="created_at"    not-null="true" />
    <filter name="tenant_filter" condition="customer_id = :tenantId" />
  </class>
</hibernate-mapping>
