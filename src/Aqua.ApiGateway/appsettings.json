{
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "JwtAuthority": "http://identity-service:8080",
    "JwtAudience": "aqua-api",
    "Services": []
  },
  "TenantResolution": {
    "Mode": "Subdomain",
    "SubdomainPattern": "^([a-z0-9][a-z0-9-]{1,30})\\.aqua-cloud\\.io$",
    "ReservedSubdomains": ["www", "api", "admin", "status"],
    "DefaultTenant": null,
    "HeaderName": "X-Aqua-Tenant"
  },
  "RateLimits": {
    "PerIp":     { "PermitLimit": 100,  "WindowSeconds": 10 },
    "PerTenant": { "PermitLimit": 1000, "WindowSeconds": 60 },
    "PerUser":   { "PermitLimit": 600,  "WindowSeconds": 60 }
  },
  "Resilience": {
    "RetryAttempts": 2,
    "RetryBaseDelayMilliseconds": 200,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerMinimumThroughput": 10,
    "CircuitBreakerSamplingDurationSeconds": 30,
    "CircuitBreakerBreakDurationSeconds": 15,
    "RequestTimeoutSeconds": 30
  }
}
