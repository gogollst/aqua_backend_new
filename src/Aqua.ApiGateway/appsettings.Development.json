{
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Information" }
  },
  "Gateway": {
    "JwtAuthority": "http://identity-service:8080",
    "JwtAudience": "aqua-api",
    "JwtRequireHttpsMetadata": false,
    "Services": [
      {
        "Name": "identity",
        "BaseUrl": "http://identity-service:8080",
        "PathPrefix": "/api/v1/auth",
        "AnonymousPaths": ["/token", "/refresh"]
      },
      {
        "Name": "identity-disco",
        "BaseUrl": "http://identity-service:8080",
        "PathPrefix": "/.well-known",
        "AnonymousPaths": ["*"]
      }
    ]
  },
  "TenantResolution": {
    "Mode": "Default",
    "DefaultTenant": "default",
    "HeaderName": "X-Aqua-Tenant"
  }
}
