{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "NHibernate": "Warning",
      "MassTransit": "Information"
    }
  },
  "AquaData": {
    "Tenants": {
      "acme":    { "Dbms": "Postgres", "ConnectionString": "Host=localhost;Port=5432;Database=aqua_acme;Username=aqua;Password=aqua-dev;Include Error Detail=true" },
      "default": { "Dbms": "Postgres", "ConnectionString": "Host=localhost;Port=5432;Database=aqua_default;Username=aqua;Password=aqua-dev;Include Error Detail=true" }
    }
  },
  "MassTransit": {
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "VirtualHost": "aqua-acme",
      "Username": "aqua",
      "Password": "aqua-dev"
    }
  },
  "Storage": {
    "S3": {
      "Endpoint": "http://localhost:9000",
      "AccessKey": "aqua-dev",
      "SecretKey": "aqua-dev-secret",
      "ForcePathStyle": true,
      "AttachmentsBucketPattern": "aqua-attachments-{tenant}"
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=aqua-dev"
  },
  "Email": {
    "Provider": "Smtp",
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "EnableSsl": false,
      "From": "no-reply@aqua-dev.local"
    }
  },
  "Otel": {
    "ServiceName": "REPLACE-PER-SERVICE",
    "Exporters": {
      "Console": true,
      "Otlp": null
    }
  }
}
